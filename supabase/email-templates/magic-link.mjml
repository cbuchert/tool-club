<mjml>
	<mj-head>
		<mj-title>Sign in to Tool Club</mj-title>
		<mj-preview>Your sign-in link for Tool Club</mj-preview>
		<mj-font
			name="Fraunces"
			href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500&display=swap"
		/>
		<mj-attributes>
			<mj-all
				font-family="-apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif"
				font-size="14px"
				color="#1a1a18"
				line-height="1.6"
			/>
		</mj-attributes>
	</mj-head>

	<mj-body background-color="#f5f4f0">
		<!-- Wordmark -->
		<mj-section padding="40px 0 0">
			<mj-column>
				<mj-text
					align="center"
					font-family="'Fraunces', Georgia, serif"
					font-size="22px"
					font-weight="500"
					color="#1a1a18"
					letter-spacing="-0.3px"
				>
					Tool Club
				</mj-text>
			</mj-column>
		</mj-section>

		<!-- Card -->
		<mj-section
			background-color="#ffffff"
			border-radius="12px"
			border="1px solid rgba(0,0,0,0.08)"
			padding="28px 28px 24px"
			css-class="card"
		>
			<mj-column>
				<mj-text
					font-family="'Fraunces', Georgia, serif"
					font-size="20px"
					font-weight="500"
					color="#1a1a18"
					letter-spacing="-0.2px"
					padding-bottom="6px"
				>
					Sign in to Tool Club
				</mj-text>

				<mj-text color="#5f5e5a" padding-bottom="24px">
					Click the button below to sign in. This link expires in 1 hour and can only be used once.
				</mj-text>

				<mj-button
					background-color="#3b6d11"
					border-radius="8px"
					color="#ffffff"
					font-size="14px"
					font-weight="500"
					inner-padding="10px 24px"
					href="{{ .ConfirmationURL }}"
					align="left"
				>
					Sign in to Tool Club
				</mj-button>
			</mj-column>
		</mj-section>

		<!-- Footer -->
		<mj-section padding="20px 0 40px">
			<mj-column>
				<mj-text align="center" font-size="11px" color="#888780">
					This email was sent because someone requested a sign-in link for your account at
					<a href="{{ .SiteURL }}" style="color: #888780">toolclub.app</a>. If you didn't request
					this, you can safely ignore this email.
				</mj-text>
			</mj-column>
		</mj-section>
	</mj-body>
</mjml>
